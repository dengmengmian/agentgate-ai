{
  "name": "agentgate",
  "private": true,
  "version": "1.4.11",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm provider:catalog:check && tsc && vite build",
    "preview": "vite preview",
    "provider:catalog:generate": "node scripts/generate-provider-catalog.mjs",
    "provider:catalog:check": "node scripts/generate-provider-catalog.mjs --check",
    "provider:catalog:sync": "node scripts/sync-provider-catalog.mjs",
    "provider:catalog:sync:check": "node scripts/sync-provider-catalog.mjs --check",
    "docs:download:check": "node scripts/check-download-docs.mjs",
    "release:notes": "node scripts/extract-release-notes.mjs",
    "release:preflight": "bash scripts/release-preflight.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci-local": "bash scripts/test-ci-local.sh",
    "test:playwright": "pnpm build && node scripts/test-playwright-smoke.mjs",
    "test:quickstart": "bash scripts/test-quickstart-core.sh",
    "test:release-local": "bash scripts/test-release-local.sh",
    "test:ui": "vitest --ui",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.0.4",
    "vitest": "^4.1.7"
  }
}
